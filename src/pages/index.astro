---
import Layout from '../layouts/Layout.astro';
import { getNewsList } from '../lib/microcms';

// Fetch the latest 3 news posts from MicroCMS
let latestNews = [];
try {
    const response = await getNewsList({ limit: 3 });
    latestNews = response.contents;
} catch (error) {
    console.error("Error fetching news from MicroCMS:", error);
}
---

<Layout 
    title="動物ふれあい広場 | ポニー＆ヤギ・ふれあい広場" 
    description="ヤギさんとトコトコ。家族でのんびりお散歩時間。近所の家族連れや、子供の動物デビュー・食育にぴったりの、自然豊かでアットホームな動物ふれあい広場です。"
>
	<!-- Hero Section -->
    <section class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <h1 class="hero-title">
                <span class="highlight">ヤギさん</span>とトコトコ。<br>
                家族でのんびりお散歩時間。
            </h1>
            <p class="hero-subtitle">
                ポニー＆ヤギ・ふれあい広場<br>
                お子様の動物デビュー大歓迎！ベビーカーOK！
            </p>
            <div class="hero-cta">
                <a href="#service" class="btn-primary hero-btn">ふれあいメニューを見る</a>
            </div>
        </div>
    </section>

    <!-- About Section (プロフィール・想い) -->
    <section id="about" class="section section-alt">
        <div class="container about-container">
            <div class="about-text">
                <h2>私たちの想い<br><span class="h2-sub">〜ヤギさんぽで家族の思い出を〜</span></h2>
                <div class="about-content">
                    <p>
                        私たち動物ふれあい広場は、小さなお子様連れのご家族に、自然や動物と触れ合う「癒やしと学び」の時間を提供したいという想いから、ポニー＆ヤギ・ふれあい広場をオープンしました。
                    </p>
                    <p>
                        毎日忙しいパパ・ママも、のんびりと草をはむヤギの姿を見たり、新鮮な空気を吸いながら野菜畑を歩いたりすることで、心リフレッシュできるはずです。そしてそれは、子供たちにとってかけがえのない「農業体験」であり、「食育」の第一歩だと信じています。
                    </p>
                    <p>
                        ベビーカーのままでも気軽にお立ち寄りいただけるよう、ファミレスのように親しみやすく温かい空間を用意してお待ちしております。<br>
                        お子様の「初めての動物ふれあい（動物デビュー）」は、ぜひ動物ふれあい広場にお任せください！馬やヤギたちと一緒に、皆様の笑顔に出会えることを楽しみにしております。
                    </p>
                </div>
            </div>
            <!-- Image Placeholder -->
            <div class="about-image-placeholder">
                <div class="about-image-inner">
                    <div class="about-animal-icons">
                        <span class="about-animal">🐐</span>
                        <span class="about-animal about-animal--right">🐴</span>
                    </div>
                    <div class="about-family-icon">👨‍👩‍👧‍👦</div>
                    <p class="about-placeholder-text">ヤギ・ポニーと<br>家族の笑顔が集まる場所</p>
                </div>
            </div>
        </div>
    </section>


    <!-- Services Section (ふれあいメニュー) -->
    <section id="service" class="section">
        <div class="container text-center">
            <h2>ふれあいメニュー</h2>
            <p class="section-desc">動物たちと一緒に楽しい時間を過ごしましょう。</p>
            
            <div class="services-grid">
                <!-- Service 1 -->
                <div class="service-card">
                    <div class="service-icon-wrapper">
                        <span class="service-icon">🐐</span>
                    </div>
                    <h3 class="service-title">ヤギさんぽ <small>(15分)</small></h3>
                    <p class="service-price">500円</p>
                    <p class="service-detail">ヤギさんと一緒に畑の周りをお散歩。のんびりとしたペースで、お子様も安心です。</p>
                </div>

                <!-- Service 2 -->
                <div class="service-card">
                    <div class="service-icon-wrapper">
                        <span class="service-icon">🥕</span>
                    </div>
                    <h3 class="service-title">エサやり体験 <small>(にんじん1カップ)</small></h3>
                    <p class="service-price">500円</p>
                    <p class="service-detail">ヤギさんやポニーさんたちの大好物！手から直接あげるドキドキ体験をどうぞ。</p>
                </div>

                <!-- Service 3 -->
                <div class="service-card service-coming-soon">
                    <div class="service-icon-wrapper">
                        <span class="service-icon">🐴</span>
                    </div>
                    <h3 class="service-title">ポニー引き馬 <small>(準備中)</small></h3>
                    <p class="service-price">-</p>
                    <p class="service-detail">現在準備中です。ポニーの背中に乗って景色を楽しむ体験を、どうぞお楽しみに！</p>
                </div>
            </div>
            
            <!-- Notes -->
            <div class="service-notes">
                <p>※ 「完全予約制」です。下のボタンから空き確認・ご予約をお願いします。</p>
                <p>※ 雨天時は中止となります。あらかじめご了承ください。</p>
                <p class="note-highlight">✨ ベビーカーOK、お子様動物デビュー大歓迎！ ✨</p>
            </div>

            <!-- Reservation CTA Button -->
            <div class="reserve-cta">
                <a href="/reserve" class="btn-primary btn-reserve-big">
                    📅 空き状況を確認・ご予約はこちら
                    <span class="btn-reserve-arrow">→</span>
                </a>
                <p class="reserve-cta-note">※雨天時は当日朝にお知らせします</p>
            </div>
        </div>
    </section>

    <!-- News / Blog Section (お知らせ) -->
    <section id="news" class="section section-alt">
        <div class="container text-center">
            <h2>お知らせ・日記</h2>
            <p class="section-desc">動物たちの日常や最新情報をお届けします。</p>
            <div class="news-list">
                {latestNews.length > 0 ? (
                    latestNews.map((news) => (
                        <a href={`/news/${news.id}`} class="news-card">
                            <div class="news-date">
                                {new Date(news.publishedAt || news.createdAt).toLocaleDateString("ja-JP")}
                            </div>
                            <h3 class="news-title">{news.title}</h3>
                        </a>
                    ))
                ) : (
                    <div class="no-news-box">
                        <p class="no-news">📝 まだお知らせはありません。</p>
                        <p class="no-news-sub">開場情報など、お業待ちください！</p>
                    </div>
                )}
            </div>
            {latestNews.length > 0 && (
                 <a href="/news" class="btn-news-all">お知らせをもっと見る</a>
            )}
        </div>
    </section>

    <!-- Info & Access Section (営業案内) -->
    <section id="info" class="section">
        <div class="container text-center">
            <h2>営業案内・アクセス</h2>
            <p class="section-desc">完全予約制です。リンクからお気軽にご予約ください。</p>
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-icon">📍</span>
                    <strong>場所</strong>
                    <p>動物ふれあい広場<br><small>（※予約完了後にご案内）</small></p>
                </div>
                <div class="info-item">
                    <span class="info-icon">🅿️</span>
                    <strong>駐車場</strong>
                    <p>ご利用いただけます</p>
                </div>
                <div class="info-item">
                    <span class="info-icon">👶</span>
                    <strong>ベビーカー</strong>
                    <p>OK！入場可能です</p>
                </div>
                <div class="info-item">
                    <span class="info-icon">☔</span>
                    <strong>雨天時</strong>
                    <p>中止となります</p>
                </div>
            </div>
            <div class="info-cta">
                <p>ご予約は下ボタンからどうぞ！</p>
                <a href="/reserve" class="btn-primary">
                    📅 空き状況を確認・予約する
                </a>
            </div>
        </div>
    </section>

</Layout>

<style>
/* Hero Section */
.hero {
    position: relative;
    /* Placeholder background color if no image */
    background-color: var(--color-primary-light);
    /* Soft gradient to represent outdoor feel */
    background: linear-gradient(to bottom, #A1C4BB, #E7D7C1);
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
}

/* Texture Pattern overlay */
.hero-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    opacity: 0.4;
    background-image: radial-gradient(var(--color-surface) 1px, transparent 1px);
    background-size: 20px 20px;
    z-index: 1;
}

.hero-content {
    position: relative;
    z-index: 2;
    background: rgba(255, 255, 255, 0.85); /* Frosty glass effect */
    padding: var(--spacing-2xl);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    max-width: 800px;
    backdrop-filter: blur(5px);
}

.hero-title {
    font-size: 3rem;
    color: var(--color-primary-dark);
    margin-bottom: var(--spacing-md);
    line-height: 1.3;
}

.highlight {
    color: var(--color-accent);
    position: relative;
    display: inline-block;
}
/* Wavy underline effect on highlight */
.highlight::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 10px;
    background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg"><path d="M0 10 Q25 20 50 10 T100 10" fill="none" stroke="%23E56B55" stroke-width="6" stroke-linecap="round"/></svg>');
    background-size: 50% 100%;
}

.hero-subtitle {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--spacing-xl);
}

.hero-btn {
    font-size: 1.2rem;
    padding: 1rem 3rem;
}

/* About Section */
.about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
}

.h2-sub {
    font-size: 1.2rem;
    color: var(--color-secondary-dark);
    display: block;
    margin-top: 0.5rem;
    font-weight: 500;
}

.about-content {
    font-size: 1.05rem;
    line-height: 1.9;
}

.about-image-placeholder {
    background: linear-gradient(135deg, var(--color-primary-light) 0%, #d4ead0 100%);
    border-radius: var(--radius-lg);
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-dark);
    font-weight: 700;
    border: 3px solid var(--color-primary);
    transform: rotate(2deg);
    transition: transform 0.3s ease;
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.about-image-placeholder:hover {
    transform: rotate(0deg);
}

.about-image-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xl);
}

.about-animal-icons {
    display: flex;
    gap: var(--spacing-xl);
    font-size: 3rem;
    margin-bottom: var(--spacing-sm);
}

.about-animal {
    display: inline-block;
    animation: sway 3s ease-in-out infinite;
}

.about-animal--right {
    animation-delay: 1.5s;
    animation-direction: alternate-reverse;
}

@keyframes sway {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
}

.about-family-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-xs);
}

.about-placeholder-text {
    font-size: 0.95rem;
    color: var(--color-primary-dark);
    font-weight: 600;
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
}

/* Services Section */
.text-center {
    text-align: center;
}

.section-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-2xl);
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
}

.service-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-top: 6px solid var(--color-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.service-coming-soon {
    opacity: 0.7;
    border-top-color: #CBD5E1; /* Grayout */
}

.service-icon-wrapper {
    width: 80px;
    height: 80px;
    background-color: var(--color-surface-tint);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-md);
}

.service-icon {
    font-size: 2.5rem;
}

.service-title {
    font-size: 1.4rem;
    margin-bottom: var(--spacing-xs);
}

.service-title small {
    font-size: 0.9rem;
    font-weight: normal;
    color: var(--color-text-muted);
}

.service-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--spacing-md);
}

.service-detail {
    font-size: 0.95rem;
    color: var(--color-text);
}

.service-notes {
    background-color: var(--color-surface-tint);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    display: inline-block;
    text-align: left;
    margin-top: var(--spacing-lg);
}

.service-notes p {
    margin-bottom: var(--spacing-xs);
    font-weight: 500;
}

.note-highlight {
    color: var(--color-accent-dark);
    font-weight: 700 !important;
    text-align: center;
    margin-top: var(--spacing-md);
    margin-bottom: 0 !important;
}

/* Responsive */
@media (max-width: 768px) {
    .hero-title {
        font-size: 2rem;
    }
    .hero-content {
        padding: var(--spacing-lg) var(--spacing-md);
        margin: 0 var(--spacing-md);
    }
    .about-container {
        grid-template-columns: 1fr;
    }
    .about-image-placeholder {
        order: -1; /* Move image to top on mobile */
        transform: rotate(0);
        margin-bottom: var(--spacing-lg);
    }
}

/* News Section */
.news-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 800px;
    margin: 0 auto var(--spacing-xl);
}

.news-card {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: var(--spacing-lg) var(--spacing-xl);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border-left: 4px solid transparent;
}

.news-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-left-color: var(--color-secondary);
}

.news-date {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-right: var(--spacing-lg);
    min-width: 100px;
    font-weight: 500;
}

.news-title {
    margin: 0;
    font-size: 1.1rem;
    flex-grow: 1;
    color: var(--color-text);
}

.news-card:hover .news-title {
    color: var(--color-primary-dark);
}

.no-news {
    color: var(--color-text-muted);
    padding: var(--spacing-xl) 0;
}

.btn-news-all {
    display: inline-block;
    color: var(--color-primary-dark);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-primary-light);
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
    margin-top: var(--spacing-sm);
}

.btn-news-all:hover {
    color: var(--color-accent);
}

/* No-news state */
.no-news-box {
    padding: var(--spacing-2xl) 0;
    color: var(--color-text-muted);
}

.no-news {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xs);
}

.no-news-sub {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    opacity: 0.7;
}

/* Info Grid */
.info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--spacing-lg);
    margin: var(--spacing-xl) 0 var(--spacing-2xl);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
}

.info-item {
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.info-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
}

.info-icon {
    font-size: 2rem;
    margin-bottom: var(--spacing-xs);
}

.info-item strong {
    color: var(--color-primary-dark);
    font-size: 0.95rem;
}

.info-item p {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
}

.info-cta {
    margin-top: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
}

.info-cta > p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
}

/* Reserve CTA */
.reserve-cta {
    margin-top: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
}

.btn-reserve-big {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 1.1rem var(--spacing-2xl);
    font-size: 1.1rem;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 20px rgba(229, 107, 85, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    max-width: 480px;
    text-align: center;
    justify-content: center;
}

.btn-reserve-big:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(229, 107, 85, 0.6);
}

.btn-reserve-arrow {
    font-size: 1.2rem;
    font-weight: 700;
    transition: transform 0.3s ease;
}

.btn-reserve-big:hover .btn-reserve-arrow {
    transform: translateX(4px);
}

.reserve-cta-note {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
}
</style>
