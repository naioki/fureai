---
import Layout from '../../layouts/Layout.astro';
import { getNewsList } from '../../lib/microcms';

// Fetch all news
let newsList = [];
try {
    const response = await getNewsList({ limit: 100 });
    newsList = response.contents;
} catch (error) {
    console.error("Error fetching news list:", error);
}
---

<Layout title="お知らせ一覧 | 動物ふれあい広場" description="動物ふれあい広場（ポニー＆ヤギ・ふれあい広場）からのお知らせや農園日記の一覧です。">
    <div class="page-header">
        <div class="container">
            <h1>お知らせ・農園日記</h1>
            <p>動物ふれあい広場の最新情報や、動物たちの様子をお届けします。</p>
        </div>
    </div>

    <section class="section">
        <div class="container">
            <div class="news-list-page">
                {newsList.length > 0 ? (
                    newsList.map((news) => (
                        <a href={`/news/${news.id}`} class="news-card">
                            <div class="news-date">
                                {new Date(news.publishedAt || news.createdAt).toLocaleDateString("ja-JP")}
                            </div>
                            <h2 class="news-title">{news.title}</h2>
                        </a>
                    ))
                ) : (
                    <div class="no-news-container">
                        <p class="no-news">まだお知らせはありません。</p>
                    </div>
                )}
            </div>
            
            <div class="back-link-container">
                <a href="/" class="back-link">← トップページに戻る</a>
            </div>
        </div>
    </section>
</Layout>

<style>
.page-header {
    background-color: var(--color-surface-tint);
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align: center;
    border-bottom: 1px solid rgba(197, 152, 101, 0.2);
}

.page-header p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
}

.news-list-page {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 800px;
    margin: 0 auto;
}

.news-card {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: var(--spacing-lg) var(--spacing-xl);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border-left: 4px solid transparent;
}

.news-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-left-color: var(--color-secondary);
}

.news-date {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-right: var(--spacing-xl);
    min-width: 110px;
    font-weight: 500;
}

.news-title {
    margin: 0;
    font-size: 1.2rem;
    flex-grow: 1;
    color: var(--color-text);
    font-weight: 700;
}

.news-card:hover .news-title {
    color: var(--color-primary-dark);
}

.no-news-container {
    text-align: center;
    padding: var(--spacing-3xl) 0;
}

.no-news {
    color: var(--color-text-muted);
    font-size: 1.1rem;
}

.back-link-container {
    text-align: center;
    margin-top: var(--spacing-3xl);
}

.back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color 0.3s ease;
}

.back-link:hover {
    color: var(--color-primary-dark);
}

@media (max-width: 768px) {
    .news-card {
        flex-direction: column;
        align-items: flex-start;
        padding: var(--spacing-md) var(--spacing-lg);
    }
    .news-date {
        margin-bottom: var(--spacing-xs);
    }
}
</style>
